# ============================================
# CLIENT WORK MANAGEMENT SYSTEM - ENV CONFIG
# ============================================

# Server
NODE_ENV=development
PORT=5000
TRUST_PROXY=0

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/client-work-db?retryWrites=true&w=majority

# JWT Secrets (use strong random strings in production - min 64 chars)
JWT_ACCESS_SECRET=your_super_secret_access_token_key_change_this_in_production_min_64_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_change_this_in_production_min_64_chars

# JWT Expiry
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookie Settings
COOKIE_SECURE=false
# Use true in production (Render/HTTPS), false for local HTTP.
# Set TRUST_PROXY=1 when the API is deployed behind a reverse proxy.

# CORS - Frontend URL
CLIENT_URL=http://localhost:5173
CLIENT_URL_PROD=https://work-management-three-roan.vercel.app
CLIENT_URLS=http://localhost:5173,http://127.0.0.1:5173,https://work-management-three-roan.vercel.app

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Admin Seed (used only during initial seed - change after first run)
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=admin@company.com
SEED_ADMIN_PASSWORD=Admin@123456
