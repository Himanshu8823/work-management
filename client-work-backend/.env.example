# ============================================
# CLIENT WORK MANAGEMENT SYSTEM - ENV CONFIG
# ============================================

# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/client-work-db?retryWrites=true&w=majority

# JWT Secrets (use strong random strings in production - min 64 chars)
JWT_ACCESS_SECRET=your_super_secret_access_token_key_change_this_in_production_min_64_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_change_this_in_production_min_64_chars

# JWT Expiry
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookie Settings
COOKIE_SECURE=false
# Set to true in production (requires HTTPS)

# CORS - Frontend URL
CLIENT_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Admin Seed (used only during initial seed - change after first run)
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=admin@company.com
SEED_ADMIN_PASSWORD=Admin@123456
